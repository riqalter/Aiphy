{
  "name": "aiphy-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/db/seed.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/jwt": "^1.4.2",
    "@elysiajs/swagger": "^1.3.1",
    "arctic": "^3.7.0",
    "argon2": "^0.44.0",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.29",
    "ioredis": "^5.11.1",
    "nodemailer": "^9.0.1",
    "openai": "^6.44.0",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/nodemailer": "^8.0.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  }
}
